{
  "name": "goal-tracker",
  "version": "1.0.0",
  "description": "Mac 菜单栏目标管理应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac"
  },
  "keywords": ["electron", "goal", "tracker", "menubar"],
  "author": "David Wu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "marked": "^11.0.0"
  },
  "build": {
    "appId": "com.goaltracker.app",
    "productName": "目标追踪器",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "files": [
      "main.js",
      "renderer.js",
      "slider.js",
      "index.html",
      "slider.html",
      "styles.css",
      "slider.css",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
